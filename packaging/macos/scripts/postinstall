#!/bin/sh
set -eu

resolve_target_home() {
  candidate=${3:-}
  if [ -n "$candidate" ] && [ "$candidate" != "/" ] && [ -d "$candidate" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  if [ "$(/usr/bin/id -u)" -ne 0 ] && [ -n "${HOME:-}" ] &&
     [ "$HOME" != "/" ] && [ -d "$HOME" ]; then
    printf '%s\n' "$HOME"
    return
  fi

  invoking_user=${SUDO_USER:-}
  if [ -n "$invoking_user" ] && [ "$invoking_user" != "root" ]; then
    /usr/bin/dscl . -read "/Users/$invoking_user" NFSHomeDirectory |
      /usr/bin/awk '{print $2}'
    return
  fi

  console_user=$(/usr/bin/stat -f '%Su' /dev/console 2>/dev/null || true)
  if [ -n "$console_user" ] && [ "$console_user" != "root" ]; then
    /usr/bin/dscl . -read "/Users/$console_user" NFSHomeDirectory |
      /usr/bin/awk '{print $2}'
    return
  fi

  exit 1
}

target_home=$(resolve_target_home "$@")
case "$target_home" in
  ""|"/") exit 1 ;;
esac

support="$target_home/Library/Application Support/DevEnvironmentManager"
legacy_cli_bin="$support/bin"
path_script="$support/lc-path.sh"
begin_marker='# >>> lc CLI >>>'
end_marker='# <<< lc CLI <<<'

remove_legacy_profile_hook() {
  profile=$1
  [ -f "$profile" ] || return 0
  /usr/bin/grep -Fq "$begin_marker" "$profile" || return 0
  temporary="$profile.lc-migration.$$"
  /usr/bin/awk -v begin="$begin_marker" -v end="$end_marker" '
    $0 == begin { skipping = 1; next }
    $0 == end { skipping = 0; next }
    !skipping { print }
  ' "$profile" > "$temporary"
  /bin/cat "$temporary" > "$profile"
  /bin/rm -f "$temporary"
}

remove_legacy_profile_hook "$target_home/.zprofile"
remove_legacy_profile_hook "$target_home/.bash_profile"

owner=$(/usr/bin/stat -f '%Su' "$target_home")
user_id=$(/usr/bin/id -u "$owner" 2>/dev/null || true)
if [ -n "$user_id" ]; then
  if [ "$(/usr/bin/id -u)" -eq 0 ]; then
    current_path=$(/bin/launchctl asuser "$user_id" /usr/bin/sudo -u "$owner" \
      /bin/launchctl getenv PATH 2>/dev/null || true)
  else
    current_path=$(/bin/launchctl getenv PATH 2>/dev/null || true)
  fi
  if [ -n "${current_path:-}" ]; then
    updated_path=$(/bin/echo "$current_path" | /usr/bin/awk -v RS=: -v ORS=: \
      -v remove="$legacy_cli_bin" '$0 != remove && $0 != "" { print }' |
      /usr/bin/sed 's/:$//')
    if [ "$updated_path" != "$current_path" ]; then
      if [ "$(/usr/bin/id -u)" -eq 0 ]; then
        /bin/launchctl asuser "$user_id" /usr/bin/sudo -u "$owner" \
          /bin/launchctl setenv PATH "$updated_path" >/dev/null 2>&1 || true
      else
        /bin/launchctl setenv PATH "$updated_path" >/dev/null 2>&1 || true
      fi
    fi
  fi
fi

/bin/rm -f "$legacy_cli_bin/lc" "$legacy_cli_bin/lc-uninstall" "$path_script"
/bin/rmdir "$legacy_cli_bin" 2>/dev/null || true

exit 0
